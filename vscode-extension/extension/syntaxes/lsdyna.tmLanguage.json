{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LS-DYNA",
  "scopeName": "source.lsdyna",
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#parameter" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "match": "^\\$.*$",
      "name": "comment.line.dollar.lsdyna"
    },
    "keyword": {
      "match": "^\\*\\w[\\w_/]*",
      "name": "keyword.other.lsdyna"
    },
    "parameter": {
      "match": "&\\w+",
      "name": "variable.parameter.lsdyna"
    },
    "number": {
      "match": "(?<![\\w])[-+]?[0-9]*\\.?[0-9]+([eEdD][-+]?[0-9]+)?(?![\\w])",
      "name": "constant.numeric.lsdyna"
    }
  }
}
